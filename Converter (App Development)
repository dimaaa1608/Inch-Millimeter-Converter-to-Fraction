from kivy.app import App
from kivy.uix.boxlayout import BoxLayout
from kivy.uix.label import Label
from kivy.uix.textinput import TextInput
from kivy.uix.button import Button
from kivy.uix.screenmanager import ScreenManager, Screen
from kivy.core.window import Window

# Keeps the keyboard from covering your work
Window.softinput_mode = 'below_target'

class AppSettings:
    denominator = 64

class SettingsScreen(Screen):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        # Background is black by default in Kivy screens
        layout = BoxLayout(orientation='vertical', padding=50, spacing=30)
        
        layout.add_widget(Label(text="PRECISION", font_size=50, bold=True))
        layout.add_widget(Label(text="Set Denominator\n(16, 32, 64, 128)", font_size=35, halign='center'))
        
        # Dark box with white text for settings
        self.prec_input = TextInput(text=str(AppSettings.denominator), multiline=False, 
                                    input_filter='int', font_size=80, halign='center',
                                    background_color=(0.1, 0.1, 0.1, 1), foreground_color=(1, 1, 1, 1),
                                    cursor_color=(1, 1, 1, 1))
        layout.add_widget(self.prec_input)
        
        save_btn = Button(text="SAVE & BACK", size_hint_y=None, height=140, 
                          background_color=(0, 0.7, 0, 1), font_size=40)
        save_btn.bind(on_press=self.save_settings)
        layout.add_widget(save_btn)
        
        self.add_widget(layout)

    def save_settings(self, instance):
        try:
            val = int(self.prec_input.text)
            AppSettings.denominator = val if val > 0 else 64
        except:
            AppSettings.denominator = 64
        self.manager.current = 'main'

class MainScreen(Screen):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.layout = BoxLayout(orientation='vertical', padding=25, spacing=15)

        # Header Section
        nav = BoxLayout(size_hint_y=None, height=120)
        nav.add_widget(Label(text="MEASURE", font_size=45, bold=True))
        settings_btn = Button(text="SETTINGS", size_hint_x=None, width=280, font_size=30, 
                              background_color=(0.3, 0.3, 0.3, 1))
        settings_btn.bind(on_press=lambda x: setattr(self.manager, 'current', 'settings'))
        nav.add_widget(settings_btn)
        self.layout.add_widget(nav)

        # MM Field: Blue text on Black background
        self.layout.add_widget(Label(text="MILLIMETERS", font_size=30, color=(0.7, 0.7, 1, 1)))
        self.mm_input = TextInput(hint_text="0", multiline=False, font_size=75, halign='center',
                                  background_color=(0.1, 0.1, 0.1, 1), foreground_color=(0.5, 0.8, 1, 1),
                                  cursor_color=(1, 1, 1, 1))
        self.mm_input.bind(text=self.update_from_mm)
        self.layout.add_widget(self.mm_input)

        # Decimal Inch Field: Peach text on Black background
        self.layout.add_widget(Label(text="DECIMAL INCHES", font_size=30, color=(1, 0.7, 0.7, 1)))
        self.inch_input = TextInput(hint_text="0.0", multiline=False, font_size=75, halign='center',
                                    background_color=(0.1, 0.1, 0.1, 1), foreground_color=(1, 0.7, 0.5, 1),
                                    cursor_color=(1, 1, 1, 1))
        self.inch_input.bind(text=self.update_from_inch)
        self.layout.add_widget(self.inch_input)

        # FRACTION FIELD: Fixed! Lime text on Black background
        self.layout.add_widget(Label(text="FRACTION (e.g. 1 1/4)", font_size=30, color=(0.7, 1, 0.7, 1)))
        self.frac_input = TextInput(hint_text="0 0/0", multiline=False, font_size=75, halign='center',
                                    background_color=(0.1, 0.1, 0.1, 1), foreground_color=(0.2, 1, 0.2, 1),
                                    cursor_color=(1, 1, 1, 1))
        self.frac_input.bind(text=self.update_from_frac)
        self.layout.add_widget(self.frac_input)

        self.add_widget(self.layout)

    def simplify(self, num, den):
        while num > 0 and num % 2 == 0 and den % 2 == 0:
            num //= 2
            den //= 2
        return "" if num == 0 else f"{num}/{den}"

    def update_from_mm(self, instance, value):
        if self.mm_input.focus:
            try:
                v = float(value.replace(",", "."))
                inch_val = v / 25.4
                self.inch_input.text = str(round(inch_val, 4))
                self.frac_input.text = self.calc_frac_string(inch_val)
            except: pass

    def update_from_inch(self, instance, value):
        if self.inch_input.focus:
            try:
                v = float(value.replace(",", "."))
                self.mm_input.text = str(round(v * 25.4, 4))
                self.frac_input.text = self.calc_frac_string(v)
            except: pass

    def update_from_frac(self, instance, value):
        if self.frac_input.focus:
            try:
                parts = value.split()
                dec = 0.0
                for p in parts:
                    if "/" in p:
                        n, d = p.split("/")
                        dec += float(n) / float(d)
                    else:
                        dec += float(p)
                self.inch_input.text = str(round(dec, 4))
                self.mm_input.text = str(round(dec * 25.4, 4))
            except: pass

    def calc_frac_string(self, decimal_inch):
        total_units = int(round(decimal_inch * AppSettings.denominator))
        whole = total_units // AppSettings.denominator
        rem = total_units % AppSettings.denominator
        frac = self.simplify(rem, AppSettings.denominator)
        res = f"{whole}" if whole > 0 else ""
        if frac: res += f" {frac}" if res else frac
        return res if res else "0"

class ConverterApp(App):
    def build(self):
        sm = ScreenManager()
        sm.add_widget(MainScreen(name='main'))
        sm.add_widget(SettingsScreen(name='settings'))
        return sm

if __name__ == "__main__":
    ConverterApp().run()
